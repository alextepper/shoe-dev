# Copy to backend/.env and fill in from https://console.cloudinary.com/

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: root folder in Cloudinary (default: shoe-dev)
# CLOUDINARY_FOLDER=shoe-dev

JWT_SECRET=change-me-in-production
PORT=3001

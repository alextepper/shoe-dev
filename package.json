{
  "name": "shoe-dev",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install",
    "seed": "npm run seed -w shoe-dev-backend",
    "dev:backend": "npm run dev -w shoe-dev-backend",
    "dev:frontend": "npm run dev -w shoe-dev-frontend",
    "dev": "npm run seed && concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build -w shoe-dev-frontend",
    "start": "npm run seed -w shoe-dev-backend && node backend/src/index.js",
    "start:backend": "npm run start -w shoe-dev-backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}

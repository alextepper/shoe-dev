{
  "$schema": "https://schema.railpack.com",
  "buildAptPackages": ["python3", "make", "g++"],
  "steps": {
    "install": {
      "commands": [
        "npm install --prefix backend",
        "npm install --prefix frontend"
      ]
    },
    "build": {
      "commands": ["npm run build --prefix frontend"]
    }
  },
  "deploy": {
    "startCommand": "npm run seed --prefix backend && node backend/src/index.js"
  }
}
